#pragma once

#define LLMQORE_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#define LLMQORE_VERSION_MINOR @PROJECT_VERSION_MINOR@
#define LLMQORE_VERSION_PATCH @PROJECT_VERSION_PATCH@

#define LLMQORE_VERSION_STRING "@PROJECT_VERSION@"

#define LLMQORE_VERSION_CHECK(major, minor, patch) \
    ((major << 16) | (minor << 8) | (patch))

#define LLMQORE_VERSION \
    LLMQORE_VERSION_CHECK(LLMQORE_VERSION_MAJOR, LLMQORE_VERSION_MINOR, LLMQORE_VERSION_PATCH)
